# Copy this file to `.env` and fill in your values.

# --- Agent reasoning model (Volcengine Ark) ---
# Needed only to actually chat with the agent; the tunnel itself needs no model.
MODEL_AGENT_PROVIDER=openai
MODEL_AGENT_NAME=doubao-seed-1-6-250615
MODEL_AGENT_API_BASE=https://ark.cn-beijing.volces.com/api/v3/
MODEL_AGENT_API_KEY=your-ark-api-key-here

# --- Tunnel-layer auth ---
# Shared token a connector must present to register to the agent. Pick any
# strong random string; set the same value on both the cloud app and the
# connector.
TUNNEL_TOKEN=change-me-to-a-strong-random-token
